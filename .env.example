# Explorer transaction URL prefix (optional, default https://testnet.arcscan.app/tx/)
NEXT_PUBLIC_ARC_EXPLORER_TX=https://testnet.arcscan.app/tx/

# Block to start SaveCreated log scanning from (optional, default 0)
# Set to the factory deployment block to speed up Sync.
NEXT_PUBLIC_FACTORY_FROM_BLOCK=0

# Chunk size for provider.getLogs when scanning logs (optional, default 35000)
NEXT_PUBLIC_FACTORY_LOG_CHUNK=35000
